# mutated_skills/master_admin/crypto_vault.py
import base64

def execute(user_input):
    try:
        # Splits the command into action (encode/decode) and the text
        if ":" not in user_input:
            return "❌ Format error. Use 'encode:text' or 'decode:text'"
        
        action, text = user_input.split(":", 1)
        action = action.strip().lower()
        
        if action == "encode":
            encoded_bytes = base64.b64encode(text.encode("utf-8"))
            return f"🔒 Encoded Message: {encoded_bytes.decode('utf-8')}"
        elif action == "decode":
            decoded_bytes = base64.b64decode(text.encode("utf-8"))
            return f"🔓 Decoded Message: {decoded_bytes.decode('utf-8')}"
        else:
            return "❌ Unknown action. Use 'encode' or 'decode'."
    except Exception as e:
        return f"❌ Crypto error: {str(e)}"

# mutated_skills/master_admin/text_analyzer.py

def execute(user_input):
    if not user_input.strip():
        return "⚠️ Text payload is empty."
        
    char_count = len(user_input)
    word_count = len(user_input.split())
    line_count = len(user_input.splitlines())
    
    # Estimates reading time based on an average 200 words per minute
    reading_time = round(word_count / 200, 1) if word_count > 0 else 0
    
    return f"📊 **Text Analytics completed:**\n- Lines: {line_count}\n- Words: {word_count}\n- Characters: {char_count}\n- Est. Reading Time: {reading_time} minutes"
